#!/bin/bash
# Genesis pre-push hook — block ALL direct pushes to main on origin
# Private/fork remotes are unrestricted — users own their forks.
# Portable copy: lives in scripts/hooks/, symlinked by scripts/install.sh

remote="$1"

# Only protect the public repo (origin). Private forks can force push freely.
if [ "$remote" != "origin" ]; then
    exit 0
fi

while read local_ref local_oid remote_ref remote_oid; do
    if echo "$remote_ref" | grep -qE 'refs/heads/(main|master)$'; then
        # Block ALL direct pushes to main — force or fast-forward.
        # The only way to update main is via PR merge (gh pr merge).
        echo "BLOCKED: Direct push to $remote_ref on origin is not allowed."
        echo "Use a feature branch and PR instead: git push -u origin <branch>"
        exit 1
    fi
done

exit 0
