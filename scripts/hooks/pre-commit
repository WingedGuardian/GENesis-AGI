#!/bin/bash
# Genesis pre-commit hook — block secrets, large files, and warn on direct-to-main
# Portable copy: lives in scripts/hooks/, symlinked by scripts/install.sh

# Block direct commits to main — use a feature branch
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
    if [ "${GENESIS_ALLOW_MAIN_COMMIT:-}" = "1" ]; then
        echo "OVERRIDE: Direct commit to '$current_branch' allowed (GENESIS_ALLOW_MAIN_COMMIT=1)."
    else
        echo ""
        echo "BLOCKED: Direct commit to '$current_branch'."
        echo ""
        echo "This is not a warning. The commit has been rejected."
        echo ""
        echo "Use a feature branch:"
        echo "  git checkout -b <scope>/<description>"
        echo "  git commit ..."
        echo "  git checkout main && git merge <branch>"
        echo ""
        echo "ONLY if the user explicitly approved a direct-to-main commit:"
        echo "  GENESIS_ALLOW_MAIN_COMMIT=1 git commit ..."
        echo ""
        exit 1
    fi
fi

# Block .env and secrets files (allow .example templates)
if git diff --cached --name-only | grep -vE '\.example$' | grep -qE '\.env$|\.env\.|secrets\.env|secrets\.json'; then
    echo "BLOCKED: Secrets/env file staged for commit. Remove with: git reset HEAD <file>"
    exit 1
fi

# Block common secret patterns (exclude tests/ — test fixtures use fake keys)
if git diff --cached --diff-filter=ACM -z -- '*.py' '*.js' '*.json' '*.yml' '*.yaml' '*.toml' '*.md' \
   ':!tests/*' ':!test_*' | \
   grep -PIz '(?i)(sk-[a-zA-Z0-9]{20,}|AKIA[A-Z0-9]{16}|ghp_[a-zA-Z0-9]{36}|-----BEGIN (RSA |EC )?PRIVATE KEY-----)' 2>/dev/null; then
    echo "BLOCKED: Possible secret/API key detected in staged changes."
    echo "If this is a false positive, commit with --no-verify (but think twice)."
    exit 1
fi

# Block files over 5MB
large_files=$(git diff --cached --name-only --diff-filter=ACM | while read f; do
    size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
    if [ "$size" -gt 5242880 ]; then
        echo "$f ($(( size / 1024 / 1024 ))MB)"
    fi
done)

if [ -n "$large_files" ]; then
    echo "BLOCKED: Files over 5MB:"
    echo "$large_files"
    exit 1
fi

# Lint staged Python files with ruff
staged_py=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$staged_py" ]; then
    if command -v ruff &>/dev/null; then
        if ! ruff check $staged_py; then
            echo "BLOCKED: ruff lint errors in staged Python files. Fix and re-stage."
            exit 1
        fi
    fi
fi

# Warn on new non-code files (catch accidental LLM output in repo)
ALLOWED_EXT='\.py$|\.pyi$|\.sh$|\.bash$|\.yaml$|\.yml$|\.json$|\.toml$|\.html$|\.css$|\.js$|\.cfg$|\.ini$|\.sql$|\.lock$'
ALLOWED_NAMES='Makefile$|Dockerfile$|\.gitignore$|\.gitattributes$'
new_noncodes=$(git diff --cached --name-only --diff-filter=A | grep -vE "$ALLOWED_EXT|$ALLOWED_NAMES" || true)
if [ -n "$new_noncodes" ]; then
    echo ""
    echo "WARNING: New non-code file(s) staged:"
    echo "$new_noncodes"
    echo ""
    echo "Genesis output files belong in ~/.genesis/output/, not the repo."
    echo "If this file is intentional source/product content, proceed."
    echo ""
fi

# Strip GitNexus's auto-injected block from staged CLAUDE.md.
# The post-commit hook runs `npx gitnexus analyze`, which re-injects a
# <!-- gitnexus:start --> … <!-- gitnexus:end --> block into BOTH CLAUDE.md and
# AGENTS.md on every commit (it has no per-file flag). We keep it in AGENTS.md
# (read by cross-tool agents) but it must never enter CLAUDE.md. The hourly
# run_gitnexus_strip job cleans the working tree, but a commit or worktree cut
# in the window between re-inject and strip captures it — so strip it here, at
# the index, where it can never reach a commit. Operates on the staged blob, so
# unrelated working-tree edits to CLAUDE.md are left untouched.
if git diff --cached --name-only --diff-filter=ACM | grep -qxF 'CLAUDE.md'; then
    if command -v python3 >/dev/null 2>&1; then
        python3 - <<'PY'
import re, subprocess, sys

# Anchor the start marker to column 0 (re.MULTILINE) so authored prose that
# merely *mentions* the markers mid-line is never matched; gitnexus always
# injects the block at line start. surrogateescape keeps a non-UTF8 byte a
# lossless no-op instead of hard-blocking an unrelated commit.
PATTERN = re.compile(
    r"\n*^<!-- gitnexus:start -->.*?<!-- gitnexus:end -->[^\n]*\n?",
    re.DOTALL | re.MULTILINE,
)

staged = subprocess.run(
    ["git", "cat-file", "blob", ":CLAUDE.md"], capture_output=True,
).stdout.decode("utf-8", "surrogateescape")
stripped = PATTERN.sub("\n", staged)
if stripped == staged:
    sys.exit(0)  # no block staged — nothing to do

new_hash = subprocess.run(
    ["git", "hash-object", "-w", "--stdin"],
    input=stripped.encode("utf-8", "surrogateescape"), capture_output=True,
).stdout.decode().strip()
subprocess.run(
    ["git", "update-index", "--cacheinfo", f"100644,{new_hash},CLAUDE.md"],
    check=True,
)

# Mirror the strip to the working tree when it carries the same block, so the
# file does not immediately re-appear as modified after the commit.
try:
    with open("CLAUDE.md", encoding="utf-8", errors="surrogateescape") as fh:
        wt = fh.read()
    wt_stripped = PATTERN.sub("\n", wt)
    if wt_stripped != wt:
        with open("CLAUDE.md", "w", encoding="utf-8", errors="surrogateescape") as fh:
            fh.write(wt_stripped)
except OSError:
    pass

sys.exit(10)  # signal: block was stripped
PY
        rc=$?
        if [ "$rc" = "10" ]; then
            echo "pre-commit: stripped auto-injected GitNexus block from staged CLAUDE.md (kept in AGENTS.md)."
        elif [ "$rc" != "0" ]; then
            echo "BLOCKED: failed to strip GitNexus block from CLAUDE.md (python3 exit $rc)." >&2
            echo "Resolve manually, or commit with --no-verify if you are certain." >&2
            exit 1
        fi
    else
        echo "WARNING: python3 not found — cannot strip GitNexus block from CLAUDE.md."
    fi
fi

# Phase 6 — verify tracked hook changes are recorded in .genesis-hook-versions
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/scripts/check_hook_versions.sh" ]; then
    if ! "$REPO_ROOT/scripts/check_hook_versions.sh"; then
        exit 1
    fi
fi

exit 0
