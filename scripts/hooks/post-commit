#!/usr/bin/env bash
# Phase 6 — contribution pipeline trigger.
#
# Detects `fix:` commits and emits a pending-offer marker so Genesis can
# offer to contribute the fix upstream on the next user prompt.
#
# Opt-out: use `fix(local):` scope to skip the offer.
#
# Failure semantics: fail-open. Any error inside this hook must NEVER block
# the user's commit flow. All output goes to a log file, not stderr.

set -u  # catch unset vars; deliberately NOT -e so errors don't block commits

HOME="${HOME:-$(eval echo ~)}"
GENESIS_HOME="${GENESIS_HOME:-$HOME/.genesis}"
LOG_FILE="$GENESIS_HOME/contribution-hook.log"
PENDING_DIR="$GENESIS_HOME/pending-offers"

_log() {
    mkdir -p "$GENESIS_HOME" 2>/dev/null || return 0
    printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >> "$LOG_FILE" 2>/dev/null || true
}

# Read the commit that just landed. --no-color avoids ANSI pollution.
COMMIT_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
COMMIT_SUBJECT=$(git log -1 --format=%s HEAD 2>/dev/null || echo "")

if [[ -z "$COMMIT_SHA" || -z "$COMMIT_SUBJECT" ]]; then
    _log "skip: could not read HEAD (sha='$COMMIT_SHA' subject='$COMMIT_SUBJECT')"
    exit 0
fi

# ─── Code intelligence reindex (every commit, fire-and-forget) ────────────
# Keeps codebase-memory-mcp and GitNexus indexes fresh after each commit —
# via the single locked entrypoint ONLY. This hook fires for commits in
# EVERY worktree (hooks live in the git common dir); the raw spawns that
# used to live here piled three concurrent uncapped indexers onto one
# worktree and wedged the container (D-state I/O storm). The entrypoint
# enforces worktree-skip, a per-repo single-flight lock, and resource caps.
# Fail-open: errors logged, never block the commit.
_REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [[ -n "$_REPO_ROOT" && -f "$_REPO_ROOT/scripts/lib/code_intel_index.sh" ]]; then
    _CI_LOG="$GENESIS_HOME/code-intelligence-hook.log"
    ( bash "$_REPO_ROOT/scripts/lib/code_intel_index.sh" "$_REPO_ROOT" both \
        >> "$_CI_LOG" 2>&1 ) &
    disown 2>/dev/null || true
fi

# ─── Stale-branch cleanup on public releases ──────────────────────────────
# When a commit with subject matching `Genesis v...public release` lands,
# most feature branches whose work was squash-merged become orphaned. Run
# the cleanup script with --auto-delete to reap them. Fail-open: errors
# are logged and swallowed, never blocking the release commit.
if [[ "$COMMIT_SUBJECT" =~ ^Genesis[[:space:]]+v[0-9]+.*public[[:space:]]release ]]; then
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
    CLEANUP_SCRIPT="$REPO_ROOT/scripts/cleanup-stale-branches.sh"
    if [[ -n "$REPO_ROOT" && -x "$CLEANUP_SCRIPT" ]]; then
        _log "release detected (sha=$COMMIT_SHA), running stale-branch cleanup"
        # Background it — branch cleanup touches refs but is idempotent.
        ( bash "$CLEANUP_SCRIPT" --auto-delete >> "$LOG_FILE" 2>&1 ) &
        disown 2>/dev/null || true
    else
        _log "release detected but cleanup script missing/not-executable: $CLEANUP_SCRIPT"
    fi
fi

# ─── Contribution offer gate (config-driven) ────────────────────────────────
# Check config/contribution.local.yaml first (user override), then base config.
# Default: enabled (if neither file exists or key is absent).
# Mirrors the Python settings layer's deep-merge: local overrides base per-key.
# IMPORTANT: resolve config from the MAIN repo root, not the worktree.
# .local.yaml files are gitignored and only exist in the main checkout.
# In worktrees, git-common-dir points to the main .git, whose parent is the
# main repo root.
if [[ -n "$_REPO_ROOT" ]]; then
    _GIT_COMMON=$(git rev-parse --git-common-dir 2>/dev/null || echo "")
    if [[ -n "$_GIT_COMMON" && "$_GIT_COMMON" != ".git" ]]; then
        # In a worktree: git-common-dir is an absolute path to the main .git
        _MAIN_ROOT=$(cd "$_GIT_COMMON/.." 2>/dev/null && pwd -P)
    else
        # In the main checkout: repo root IS the main root
        _MAIN_ROOT="$_REPO_ROOT"
    fi
    _CONTRIB_CFG_DIR="$_MAIN_ROOT/config"
    _CONTRIB_DISABLED=""
    # Local override takes precedence (if the key is present in it)
    if [[ -f "$_CONTRIB_CFG_DIR/contribution.local.yaml" ]] \
       && grep -qiE '^\s*offer_enabled:\s*(false|no|off)\s*(#.*)?$' "$_CONTRIB_CFG_DIR/contribution.local.yaml" 2>/dev/null; then
        _CONTRIB_DISABLED="local"
    # Fall through to base config (also checked when local exists but lacks the key)
    elif [[ -f "$_CONTRIB_CFG_DIR/contribution.yaml" ]] \
         && grep -qiE '^\s*offer_enabled:\s*(false|no|off)\s*(#.*)?$' "$_CONTRIB_CFG_DIR/contribution.yaml" 2>/dev/null; then
        # Only use base if local doesn't explicitly set offer_enabled to true
        if ! { [[ -f "$_CONTRIB_CFG_DIR/contribution.local.yaml" ]] \
               && grep -qiE '^\s*offer_enabled:\s*(true|yes|on)\s*(#.*)?$' "$_CONTRIB_CFG_DIR/contribution.local.yaml" 2>/dev/null; }; then
            _CONTRIB_DISABLED="base"
        fi
    fi
    if [[ -n "$_CONTRIB_DISABLED" ]]; then
        _log "skip: contribution offers disabled via $_CONTRIB_DISABLED config"
        exit 0
    fi
fi

# Match `fix:` OR `fix(scope):` BUT NOT `fix(local):`.
# The conventional commits spec allows scopes in parens; we reject scope `local`
# as the opt-out mechanism.
if [[ ! "$COMMIT_SUBJECT" =~ ^fix(\([^\)]*\))?: ]]; then
    exit 0  # not a fix commit, silently skip
fi

# Explicit opt-out: fix(local): ...
if [[ "$COMMIT_SUBJECT" =~ ^fix\(local\): ]]; then
    _log "skip opt-out: sha=$COMMIT_SHA subject=$COMMIT_SUBJECT"
    exit 0
fi

# Auto-filter: skip if ALL changed files are local-only (don't exist upstream).
# Uses git object store — no network, <10ms for typical diffs.
# If at least one file exists in origin/main, the hook fires normally and the
# sanitizer filters non-upstreamable paths. If every file is local-only, there
# is nothing to contribute upstream.
if git show-ref --verify --quiet refs/remotes/origin/main 2>/dev/null; then
    changed_files=$(git diff-tree --no-commit-id --name-only -r "$COMMIT_SHA" 2>/dev/null || true)
    if [[ -n "$changed_files" ]]; then
        has_upstream_file=false
        while IFS= read -r f; do
            if [[ -n "$f" ]] && git show "origin/main:$f" >/dev/null 2>&1; then
                has_upstream_file=true
                break
            fi
        done <<< "$changed_files"
        if [[ "$has_upstream_file" = false ]]; then
            _log "skip local-only: sha=$COMMIT_SHA (no changed files exist in origin/main)"
            exit 0
        fi
    fi
fi

# Write the marker file for the hot path.
mkdir -p "$PENDING_DIR" 2>/dev/null || { _log "err: cannot mkdir $PENDING_DIR"; exit 0; }

MARKER="$PENDING_DIR/${COMMIT_SHA}.json"
# Use a temp file + atomic rename so a half-written marker is never observed.
TMP_MARKER="$PENDING_DIR/.${COMMIT_SHA}.tmp"

# JSON-encode the subject via python3. The previous sed-based escape
# only handled backslash + double-quote, which broke on subjects with
# control chars, embedded newlines (pre-commit hooks can rewrite the
# subject line), tabs, or multi-byte characters — any of which would
# produce an invalid JSON marker and be silently unreadable by the
# consumer side. python3 is already a dependency of this hook (see the
# emit_bugfix_audit.py invocation at the bottom) so this adds no cost.
CREATED_AT=$(date -Iseconds 2>/dev/null || date)
if ! MARKER_JSON=$(
    COMMIT_SHA="$COMMIT_SHA" \
    COMMIT_SUBJECT="$COMMIT_SUBJECT" \
    CREATED_AT="$CREATED_AT" \
    python3 -c '
import json, os
print(json.dumps({
    "sha": os.environ["COMMIT_SHA"],
    "subject": os.environ["COMMIT_SUBJECT"],
    "created_at": os.environ["CREATED_AT"],
}, indent=2))
' 2>>"$LOG_FILE"); then
    _log "err: python3 JSON encode failed (rc=$?), aborting marker write"
    exit 0
fi
if [[ -z "$MARKER_JSON" ]]; then
    _log "err: python3 returned empty output, aborting marker write"
    exit 0
fi
printf '%s\n' "$MARKER_JSON" > "$TMP_MARKER"

if [[ -s "$TMP_MARKER" ]]; then
    mv "$TMP_MARKER" "$MARKER" 2>/dev/null || { _log "err: cannot rename marker"; rm -f "$TMP_MARKER"; exit 0; }
    _log "marker written: sha=$COMMIT_SHA"
else
    _log "err: tmp marker empty, aborting"
    rm -f "$TMP_MARKER"
    exit 0
fi

# Fire-and-forget audit: write a bugfix_committed observation to the DB.
# Uses a Python helper because sqlite from bash is annoying and we want UUIDs.
SCRIPT_DIR=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")
AUDIT_HELPER="$SCRIPT_DIR/emit_bugfix_audit.py"

if [[ -f "$AUDIT_HELPER" ]]; then
    # Background it so commit is never blocked on DB I/O. Pipe log to the file.
    python3 "$AUDIT_HELPER" "$COMMIT_SHA" "$COMMIT_SUBJECT" >> "$LOG_FILE" 2>&1 &
    disown 2>/dev/null || true
fi

exit 0
