[Unit]
Description=Genesis Watchdog — single health check invocation
After=agent-zero.service genesis-bridge.service
Wants=agent-zero.service

[Service]
Type=oneshot
WorkingDirectory=__REPO_DIR__
ExecStart=__VENV__/bin/python -m genesis.autonomy.watchdog_runner
Environment=PATH=__VENV__/bin:/usr/local/bin:/usr/bin:/bin
StandardOutput=journal
StandardError=journal
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=%h
