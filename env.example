# Genesis — Deployment Configuration Template
# These are deployment/topology settings, not secrets.
# Set them in your shell profile, systemd unit override, or .env at the repo root.
#
# For API keys and credentials, see secrets.env.example.

# ─── Local Inference (optional) ─────────────────────────────────────
# Ollama and LM Studio are optional add-ons for local GPU inference.
# Most users should leave GENESIS_ENABLE_OLLAMA=false and use cloud providers.

OLLAMA_URL=http://localhost:11434
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_HEALTH_URL=http://localhost:1234/v1/models

# Set to true only if you have a local Ollama or LM Studio instance.
GENESIS_ENABLE_OLLAMA=false

# ─── Services ─────────────────────────────────────────────

QDRANT_URL=http://localhost:6333
SEARXNG_URL=http://localhost:55510/search

# ─── Proactive memory hook (UserPromptSubmit) ─────────────
# The Claude Code proactive-memory hook is a thin client of the genesis-server
# recall endpoint. Recall logic lives server-side; the hook falls back to a
# degraded FTS5-only keyword search if the server is unreachable.
#
#   server (default) — call the endpoint; degrade to FTS5 on any failure
#   local            — skip the endpoint, always use the FTS5 degraded path
#   off              — session-local awareness only, no memory recall
# GENESIS_PROACTIVE_HOOK_MODE=server
#
# Base URL of the local genesis-server (loopback). Override if you run the
# server on a non-default host/port (see `python -m genesis serve --port`).
# GENESIS_PROACTIVE_HOOK_URL=http://127.0.0.1:5000

# ─── Paths ────────────────────────────────────────────────
# Override if your venv or Agent Zero checkout live somewhere non-standard.

VENV_PATH=~/genesis/.venv
AZ_ROOT=~/agent-zero

# Override if secrets.env lives outside the genesis repo root.
# Default: ~/genesis/secrets.env
# SECRETS_PATH=~/genesis/secrets.env
