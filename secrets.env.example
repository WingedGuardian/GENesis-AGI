# Genesis — Secrets Template
# Copy and fill in your values:
#   cp secrets.env.example secrets.env
#   chmod 600 secrets.env
#
# This file contains credentials, API keys, and runtime config.
# For full documentation of each key, see the comments in secrets.env.

# ─── Telegram ────────────────────────────────────────────────────────────
# Required for the Telegram bridge. Create a bot via @BotFather.
# TELEGRAM_BOT_TOKEN: paste the token from BotFather (format: 123456:ABC-DEF...)
# TELEGRAM_ALLOWED_USERS: comma-separated numeric user IDs (NOT the bot token).
#   Get your ID: message @userinfobot on Telegram.
# TELEGRAM_FORUM_CHAT_ID: optional supergroup chat ID for topic routing (negative number)

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_FORUM_CHAT_ID=

# ─── LLM Providers (Core) ───────────────────────────────────────────────
# At minimum, configure one provider. All are optional individually.

# --- Groq ---
# Used by: 13+ call sites — triage, reflection, tagging, STT (Whisper).
# Signup: console.groq.com
# Free tier: 30 RPM on llama-3.3-70b-versatile
API_KEY_GROQ=

# --- Mistral ---
# Used by: 19 call sites — reflection, triage calibration, embeddings.
# Signup: console.mistral.ai
# Free tier: limited RPM on mistral-large-latest
API_KEY_MISTRAL=

# --- Google (Gemini) ---
# Used by: 12 call sites — consolidation, surplus, outreach, research.
# Signup: console.cloud.google.com -> APIs & Services -> Credentials
# Free tier: Gemini Flash generous free quota
GOOGLE_API_KEY=

# --- OpenRouter ---
# Used by: 16+ call sites. Model aggregator — one key covers 200+ models.
# Signup: openrouter.ai/keys
# Free tier: access to community free models
API_KEY_OPENROUTER=

# --- Anthropic (Claude API) ---
# Used by: 7 call sites — deep/strategic reflection, user model synthesis.
# Signup: console.anthropic.com
# Paid: per-token pricing
ANTHROPIC_API_KEY=

# --- DeepSeek ---
# Used by: Direct provider (deepseek-chat). Available for call site chains.
# Signup: platform.deepseek.com
# Paid: very cheap per-token pricing
API_KEY_DEEPSEEK=

# --- Alibaba (Qwen) ---
# Used by: 5 call sites — retrospective, calibration, meta prompting.
# Signup: dashscope.console.aliyun.com
# Paid: cheap per-token
API_KEY_QWEN=

# --- ZenMux (GLM-5 via aggregator) ---
# Used by: 2 call sites — cognitive state, contingency reflection.
# Signup: zenmux.ai -> Dashboard -> API Keys
# Paid: aggregator markup. OpenAI-compatible.
API_KEY_ZENMUX=

# --- MiniMax ---
# Used by: Provider configured, available for call site chains.
# Signup: platform.minimaxi.com -> API Keys
# Paid: ~$0.29/M input, ~$1.15/M output. OpenAI-compatible.
API_KEY_MINIMAX=

# ─── LLM Providers (Additional) ─────────────────────────────────────────
# Routing support exists for these providers. Leave empty to disable.

# --- OpenAI ---
# Used by: Direct provider (openai-gpt5). Also available via OpenRouter.
# Signup: platform.openai.com
OPENAI_API_KEY=

# --- xAI (Grok) ---
# Used by: Direct provider (xai-grok). Available for call site chains.
# Signup: console.x.ai
API_KEY_XAI=

# --- Cerebras ---
# Used by: High-volume free inference (14,400 RPD). Qwen3-235B instruct.
# Signup: cloud.cerebras.ai
# Free tier: 10 RPM, 14,400 RPD, 1M tokens/min
API_KEY_CEREBRAS=

# --- GitHub Models ---
# Used by: Free frontier reasoning (o3-mini 50 RPD). Azure-backed.
# Signup: github.com/marketplace/models (GitHub account required)
# Free tier: varies by model — o3-mini: 50 RPD
API_KEY_GITHUB=

# --- SambaNova ---
# Used by: Free inference (DeepSeek-R1, QwQ-32B). Custom hardware.
# Signup: cloud.sambanova.ai
# Free tier: generous limits, verify current terms
API_KEY_SAMBANOVA=

# --- Azure OpenAI ---
# Used by: Available for routing. For enterprise/Azure users.
# Signup: portal.azure.com -> Azure OpenAI Service
API_KEY_AZURE=

# --- AWS Bedrock ---
# Used by: Available for routing. For AWS users.
# Signup: aws.amazon.com -> Bedrock
API_KEY_BEDROCK=

# --- HuggingFace ---
# Used by: Available for model access and embeddings.
# Signup: huggingface.co/settings/tokens
API_KEY_HUGGINGFACE=

# ─── Search & Research ───────────────────────────────────────────────────

# --- Brave Search ---
# Used by: Web search fallback.
# Signup: brave.com/search/api
# Free tier: 2,000 queries/month
API_KEY_BRAVE=

# --- Perplexity ---
# Used by: Research provider for orchestrated research (Sonar API).
# Signup: perplexity.ai/settings/api
# Paid: ~$0.006/query (Sonar), $0.005/query (Search API)
API_KEY_PERPLEXITY=

# --- Tavily ---
# Used by: AI-optimized web search for agent pipelines.
# Signup: app.tavily.com (no credit card required)
# Free tier: 1,000 searches/month
API_KEY_TAVILY=

# --- Exa ---
# Used by: Neural/semantic web search + answer generation.
# Signup: dashboard.exa.ai (no credit card required)
# Free tier: 1,000 searches/month
API_KEY_EXA=

# --- Firecrawl ---
# Used by: Claude Code Firecrawl plugin.
# Signup: firecrawl.dev
FIRECRAWL_API_KEY=

# --- Cloudflare ---
# Used by: Web crawling provider. Requires both key and account ID.
# Signup: dash.cloudflare.com -> API Tokens
API_KEY_CLOUDFLARE=
CLOUDFLARE_ACCOUNT_ID=

# ─── TTS & Voice ─────────────────────────────────────────────────────────
# All optional. Set TTS_ENABLED=false to disable voice responses entirely.

TTS_ENABLED=true

# --- ElevenLabs ---
# Signup: elevenlabs.io -> Profile -> API Keys
API_KEY_ELEVENLABS=
TTS_VOICE_ID_ELEVENLABS=
TTS_ELEVENLABS_MODEL=eleven_flash_v2_5
# TTS_ELEVENLABS_STABILITY=0.25
# TTS_ELEVENLABS_SIMILARITY=0.20
# TTS_ELEVENLABS_STYLE=1.0
# TTS_ELEVENLABS_SPEED=1.0

# --- Cartesia Sonic ---
# Signup: cartesia.ai -> Dashboard -> API Keys
API_KEY_CARTESIA=
TTS_VOICE_ID_CARTESIA=

# --- Fish Audio ---
# Signup: fish.audio -> API Keys
API_KEY_FISH_AUDIO=
TTS_VOICE_ID_FISH=

# ─── Embeddings ──────────────────────────────────────────────────────────

# --- DeepInfra ---
# Used by: Cloud embedding fallback.
# Signup: deepinfra.com -> API Keys
API_KEY_DEEPINFRA=

# ─── Dashboard Security ──────────────────────────────────────────────────
# Set a password to protect the dashboard from unauthorized LAN access.
# Leave empty to disable auth (dashboard accessible without login).
# When set, all dashboard access requires login (30-day session cookie).

DASHBOARD_PASSWORD=

# ─── Infrastructure & Config ─────────────────────────────────────────────
# Runtime config, not secrets. Will move to dashboard settings in a future release.

# Local inference servers
OLLAMA_URL=http://localhost:11434
GENESIS_ENABLE_OLLAMA=false
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_HEALTH_URL=http://localhost:1234/v1/models

# Bridge config
WHISPER_MODEL=whisper-large-v3
DAY_BOUNDARY_HOUR=0

# User preferences
USER_TIMEZONE=UTC
GENESIS_BACKUP_PASSPHRASE=
